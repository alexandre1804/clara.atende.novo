# Supabase (use service role — nunca expor no cliente)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Evolution API (na VPS)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-global-key

# URL pública deste agente (para Evolution API enviar webhooks)
# Ex: https://agent.seudominio.com.br
AGENT_WEBHOOK_URL=https://agent.seudominio.com.br

# Porta do servidor Express
PORT=3001

# Fuso horário da VPS
TZ=America/Sao_Paulo
